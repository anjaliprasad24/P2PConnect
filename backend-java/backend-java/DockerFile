# Use official Java 17 runtime
FROM eclipse-temurin:17-jdk-alpine

# Set working directory
WORKDIR /app

# Copy project files
COPY pom.xml .
COPY src ./src

# Build the project inside Docker
RUN ./mvnw clean package -DskipTests

# Expose the port your app runs on
EXPOSE 4000

# Run Spring Boot on port 4000
CMD ["java", "-jar", "target/p2pconnect-0.0.1-SNAPSHOT.jar", "--server.port=4000"]